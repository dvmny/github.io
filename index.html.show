<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Deva Terapias | Equilíbrio e Cura em São Luís</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── Tokens ── */
    :root {
      --rose:    #f4cfd6;
      --peach:   #f7dcc8;
      --sage:    #c8dbc5;
      --lavender:#d5cfe8;
      --sky:     #c6dff0;
      --gold:    #e8c98a;

      --bg:        #fdf8f5;
      --surface:   #fff9f6;
      --card-bg:   #fffbf9;
      --text:      #3a2e2b;
      --muted:     #7a6a65;
      --border:    rgba(180,150,140,.18);
      --shadow:    0 8px 32px rgba(120,80,60,.08);
      --shadow-hover: 0 18px 48px rgba(120,80,60,.15);

      --accent1: #c9849a;   /* deeper rose */
      --accent2: #8ba88a;   /* deeper sage */
      --radius: 20px;
      --transition: .35s cubic-bezier(.4,0,.2,1);
    }

    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --bg:       #1e1a18;
        --surface:  #261f1c;
        --card-bg:  #2d2420;
        --text:     #f0e8e3;
        --muted:    #b09c95;
        --border:   rgba(255,200,180,.10);
        --shadow:   0 8px 32px rgba(0,0,0,.30);
        --shadow-hover: 0 18px 48px rgba(0,0,0,.45);
        --rose:    #6b3e4a;
        --peach:   #6b4a35;
        --sage:    #3a5438;
        --lavender:#4a4262;
        --sky:     #2e4e66;
        --gold:    #7a5e28;
        --accent1: #d9a0b4;
        --accent2: #a8c2a4;
      }
    }

    /* Manual overrides */
    :root[data-theme="dark"] {
      --bg:       #1e1a18; --surface:  #261f1c; --card-bg:  #2d2420;
      --text:     #f0e8e3; --muted:    #b09c95;
      --border:   rgba(255,200,180,.10);
      --shadow:   0 8px 32px rgba(0,0,0,.30);
      --shadow-hover: 0 18px 48px rgba(0,0,0,.45);
      --rose:#6b3e4a; --peach:#6b4a35; --sage:#3a5438;
      --lavender:#4a4262; --sky:#2e4e66; --gold:#7a5e28;
      --accent1:#d9a0b4; --accent2:#a8c2a4;
    }
    :root[data-theme="light"] {
      --bg:#fdf8f5; --surface:#fff9f6; --card-bg:#fffbf9;
      --text:#3a2e2b; --muted:#7a6a65;
      --border:rgba(180,150,140,.18);
      --shadow:0 8px 32px rgba(120,80,60,.08);
      --shadow-hover:0 18px 48px rgba(120,80,60,.15);
      --rose:#f4cfd6; --peach:#f7dcc8; --sage:#c8dbc5;
      --lavender:#d5cfe8; --sky:#c6dff0; --gold:#e8c98a;
      --accent1:#c9849a; --accent2:#8ba88a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Jost', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Blobs decorativos de fundo ── */
    .blobs {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: .55;
      animation: drift 18s ease-in-out infinite alternate;
    }
    .blob-1 { width: 420px; height: 420px; background: var(--rose);    top: -100px; left: -80px;  animation-delay: 0s; }
    .blob-2 { width: 350px; height: 350px; background: var(--lavender); top: 30%;   right: -60px; animation-delay: -6s; }
    .blob-3 { width: 300px; height: 300px; background: var(--sage);     bottom: 10%; left: 20%;   animation-delay: -12s; }

    @keyframes drift {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(30px, 20px) scale(1.06); }
    }

    /* ── Wrapper ── */
    .page { position: relative; z-index: 1; }

    /* ── Navbar ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 32px;
      background: color-mix(in srgb, var(--bg) 80%, transparent);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: .04em;
      color: var(--text);
      text-decoration: none;
    }
    .nav-logo span { color: var(--accent1); }
    .nav-cta {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 24px;
      background: var(--accent1);
      color: #fff;
      border-radius: 50px;
      font-size: .85rem;
      font-weight: 500;
      letter-spacing: .06em;
      text-decoration: none;
      transition: var(--transition);
      box-shadow: 0 4px 16px color-mix(in srgb, var(--accent1) 35%, transparent);
    }
    .nav-cta:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 8px 24px color-mix(in srgb, var(--accent1) 45%, transparent); }

    /* ── Theme toggle ── */
    .theme-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: color-mix(in srgb, var(--surface) 70%, transparent);
      backdrop-filter: blur(8px);
      cursor: pointer;
      font-size: 1.1rem;
      transition: var(--transition);
      flex-shrink: 0;
    }
    .theme-toggle:hover { transform: rotate(20deg) scale(1.1); border-color: var(--accent1); }
    .nav-right { display: flex; align-items: center; gap: 10px; }

    /* ── Hero ── */
    .hero {
      min-height: 88svh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center;
      padding: 80px 24px 60px;
    }
    .hero-moon {
      font-size: 3.2rem;
      animation: float 4s ease-in-out infinite;
      display: block; margin-bottom: 20px;
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-10px); }
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 7vw, 5rem);
      font-weight: 300;
      line-height: 1.2;
      max-width: 700px;
    }
    .hero h1 em { font-style: italic; color: var(--accent1); }
    .hero p {
      margin: 22px auto 36px;
      max-width: 480px;
      font-size: 1.05rem;
      color: var(--muted);
      font-weight: 300;
    }
    .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 32px;
      background: var(--accent1);
      color: #fff;
      border-radius: 50px;
      font-weight: 500;
      font-size: .95rem;
      letter-spacing: .05em;
      text-decoration: none;
      transition: var(--transition);
      box-shadow: 0 6px 20px color-mix(in srgb, var(--accent1) 30%, transparent);
    }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px color-mix(in srgb, var(--accent1) 42%, transparent); }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 32px;
      border: 1.5px solid var(--border);
      color: var(--text);
      border-radius: 50px;
      font-weight: 400;
      font-size: .95rem;
      text-decoration: none;
      transition: var(--transition);
      background: color-mix(in srgb, var(--surface) 60%, transparent);
      backdrop-filter: blur(8px);
    }
    .btn-secondary:hover { border-color: var(--accent1); color: var(--accent1); transform: translateY(-2px); }

    /* ── Section titles ── */
    .section-label {
      display: inline-block;
      font-size: .72rem;
      font-weight: 500;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 10px;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 300;
      line-height: 1.25;
      color: var(--text);
    }
    .section-title em { font-style: italic; color: var(--accent1); }

    /* ── Services ── */
    #servicos { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
    .services-header { text-align: center; margin-bottom: 54px; }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 28px;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: var(--transition);
      position: relative;
    }
    .card:hover {
      transform: translateY(-8px) scale(1.012);
      box-shadow: var(--shadow-hover);
    }

    .card-badge {
      position: absolute; top: 14px; right: 14px;
      background: var(--gold);
      color: #5a3c10;
      font-size: .68rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 50px;
      z-index: 2;
    }

    .card-img-wrap {
      overflow: hidden;
      height: 220px;
      position: relative;
    }
    .card-img-wrap::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 55%, color-mix(in srgb, var(--card-bg) 70%, transparent));
    }
    .card-img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .55s cubic-bezier(.4,0,.2,1);
    }
    .card:hover .card-img-wrap img { transform: scale(1.07); }

    .card-body { padding: 24px 26px 28px; }

    .card-icon { font-size: 1.5rem; margin-bottom: 6px; display: block; }

    .card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .card-desc {
      font-size: .9rem;
      color: var(--muted);
      margin-bottom: 20px;
      line-height: 1.65;
    }
    .card-price {
      display: flex; align-items: baseline; gap: 10px;
      margin-bottom: 18px;
    }
    .price-old {
      font-size: .85rem;
      color: var(--muted);
      text-decoration: line-through;
    }
    .price-new {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--accent1);
    }

    .btn-card {
      display: block; width: 100%; text-align: center;
      padding: 12px 20px;
      border-radius: 50px;
      font-size: .85rem;
      font-weight: 500;
      letter-spacing: .06em;
      text-decoration: none;
      transition: var(--transition);
      border: 1.5px solid var(--accent1);
      color: var(--accent1);
      background: color-mix(in srgb, var(--accent1) 8%, transparent);
    }
    .btn-card:hover {
      background: var(--accent1);
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 6px 18px color-mix(in srgb, var(--accent1) 30%, transparent);
    }

    /* ── Outros serviços ── */
    #outros { background: var(--surface); padding: 72px 24px; text-align: center; }
    #outros .inner { max-width: 700px; margin: 0 auto; }
    .pills {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 12px;
      margin: 32px 0 38px;
    }
    .pill {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 10px 20px;
      border-radius: 50px;
      font-size: .88rem;
      font-weight: 400;
      border: 1px solid var(--border);
      background: var(--card-bg);
      color: var(--text);
      box-shadow: var(--shadow);
      transition: var(--transition);
      cursor: default;
    }
    .pill:hover { transform: translateY(-3px) scale(1.04); box-shadow: var(--shadow-hover); border-color: var(--accent2); }

    /* ── Info strip ── */
    .info-strip {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 16px;
      max-width: 700px; margin: 0 auto;
    }
    .info-item {
      display: flex; align-items: center; gap: 10px;
      font-size: .88rem; color: var(--muted);
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 18px;
      flex: 1; min-width: 240px;
      transition: var(--transition);
    }
    .info-item:hover { transform: translateY(-2px); border-color: var(--accent2); color: var(--text); }
    .info-icon { font-size: 1.3rem; flex-shrink: 0; }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 52px 24px 40px;
      border-top: 1px solid var(--border);
    }
    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 600;
      margin-bottom: 14px;
      color: var(--text);
    }
    .footer-logo span { color: var(--accent1); }
    .footer-links {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 18px;
      margin: 12px 0 8px;
      font-size: .83rem; color: var(--muted);
    }
    .footer-links a { color: inherit; text-decoration: none; transition: color .2s; }
    .footer-links a:hover { color: var(--accent1); }
    .footer-copy { font-size: .76rem; color: var(--muted); margin-top: 16px; }
    .footer-copy a { color: var(--accent2); text-decoration: none; }

    /* ── Scroll reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .65s ease, transform .65s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      nav { padding: 12px 18px; }
      .hero { padding: 60px 18px 50px; min-height: 85svh; }
      #servicos, #outros { padding: 60px 18px; }
    }
  </style>
</head>
<body>

<!-- Decorative blobs -->
<div class="blobs" aria-hidden="true">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<div class="page">

  <!-- Nav -->
  <nav>
    <a href="#" class="nav-logo">Deva <span>Terapias</span></a>
    <div class="nav-right">
      <button class="theme-toggle" id="themeToggle" aria-label="Alternar modo claro/escuro" title="Alternar modo claro/escuro">🌙</button>
      <a href="https://wa.me/5561998635141?text=Olá!%20Gostaria%20de%20agendar" class="nav-cta" target="_blank" rel="noopener">
        💬 Agendar
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <span class="hero-moon" aria-hidden="true">🌙</span>
    <h1>Equilíbrio, <em>Cura</em> e<br>Autoconhecimento</h1>
    <p>Sua jornada de bem-estar começa aqui. Permita-se cuidar de você em São Luís&nbsp;– MA.</p>
    <div class="hero-btns">
      <a href="https://wa.me/5561998635141?text=Olá!%20Gostaria%20de%20agendar" class="btn-primary" target="_blank" rel="noopener">
        ✨ Agendar Agora
      </a>
      <a href="#servicos" class="btn-secondary">Conhecer Terapias →</a>
    </div>
  </section>

  <!-- Serviços -->
  <section id="servicos">
    <div class="services-header reveal">
      <span class="section-label">Tratamentos</span>
      <h2 class="section-title">Transforme sua <em>Energia</em></h2>
    </div>

    <div class="cards">

      <!-- Card 1 -->
      <article class="card reveal">
        <div class="card-img-wrap">
          <img src="massagem-tantrica.jpg" alt="Massagem Tântrica" loading="lazy" />
        </div>
        <div class="card-body">
          <span class="card-icon">✨</span>
          <h3 class="card-title">Massagem Tântrica</h3>
          <p class="card-desc">Expansão da consciência corporal, liberação de bloqueios emocionais e profundo relaxamento sensorial.</p>
          <div class="card-price">
            <span class="price-new">R$&nbsp;260,00</span>
          </div>
          <a href="https://wa.me/5561998635141?text=Olá!%20Gostaria%20de%20agendar%20uma%20sessão%20de%20Massagem%20Tântrica%20(R$%20260,00)" class="btn-card" target="_blank" rel="noopener">
            Agendar uma sessão
          </a>
        </div>
      </article>

      <!-- Card 2 -->
      <article class="card reveal">
        <div class="card-badge">🌿 Oferta Especial</div>
        <div class="card-img-wrap">
          <img src="massagem-ayurvedica.jpg" alt="Massagem Ayurvédica" loading="lazy" />
        </div>
        <div class="card-body">
          <span class="card-icon">🕉️</span>
          <h3 class="card-title">Massagem Ayurvédica</h3>
          <p class="card-desc">Terapia milenar indiana com óleos quentes que harmoniza doshas, equilibra mente e revitaliza o espírito.</p>
          <div class="card-price">
            <span class="price-old">R$&nbsp;299,00</span>
            <span class="price-new">R$&nbsp;199,00</span>
          </div>
          <a href="https://wa.me/5561998635141?text=Olá!%20Tenho%20interesse%20na%20promoção%20da%20Massagem%20Ayurvédica%20por%20R$%20199,00" class="btn-card" target="_blank" rel="noopener">
            Agendar uma sessão
          </a>
        </div>
      </article>

      <!-- Card 3 -->
      <article class="card reveal">
        <div class="card-img-wrap">
          <img src="massagem-terapeutica.jpg" alt="Massagem Terapêutica" loading="lazy" />
        </div>
        <div class="card-body">
          <span class="card-icon">💆</span>
          <h3 class="card-title">Massagem Terapêutica</h3>
          <p class="card-desc">Mix personalizado: massoterapia, alongamento e ventosaterapia para aliviar tensões musculares e dores.</p>
          <div class="card-price">
            <span class="price-old">R$&nbsp;221,90</span>
            <span class="price-new">R$&nbsp;149,90</span>
          </div>
          <a href="https://wa.me/5561998635141?text=Olá!%20Gostaria%20de%20agendar%20uma%20Massagem%20Terapêutica%20no%20valor%20de%20R$%20149,90" class="btn-card" target="_blank" rel="noopener">
            Agendar uma sessão
          </a>
        </div>
      </article>

    </div>
  </section>

  <!-- Outros -->
  <section id="outros">
    <div class="inner">
      <div class="reveal">
        <span class="section-label">Mais Cuidados</span>
        <h2 class="section-title">Cuidados <em>Integrativos</em></h2>
      </div>

      <div class="pills reveal">
        <span class="pill">✨ Reiki</span>
        <span class="pill">🧘 Yoga</span>
        <span class="pill">🧠 Meditação</span>
        <span class="pill">🎋 Acupuntura</span>
        <span class="pill">🌬️ Ventosaterapia</span>
        <span class="pill">🔺 Cone Hindu</span>
      </div>

      <div class="info-strip reveal">
        <div class="info-item">
          <span class="info-icon">📍</span>
          <span>Atendimentos presenciais em <strong>São Luís – MA</strong>, em ambiente acolhedor e energizado.</span>
        </div>
        <div class="info-item">
          <span class="info-icon">💛</span>
          <span>Todos os serviços com <strong>respeito, ética</strong> e foco no seu bem-estar integral.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-logo">Deva <span>Terapias</span></div>
    <div class="footer-links">
      <a href="https://instagram.com/devaamnytantra" target="_blank" rel="noopener">📸 @devaamnytantra</a>
      <a href="https://wa.me/5561998635141" target="_blank" rel="noopener">💬 (61) 99863-5141</a>
    </div>
    <p class="footer-copy">
      © 2026 Deva Terapias. Todos os direitos reservados. &nbsp;|&nbsp;
      Produzido por 🛡️ <a href="https://bunkerdigital.top" target="_blank" rel="noopener">bunkerdigital.top</a>
    </p>
  </footer>

</div><!-- .page -->

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        const siblings = e.target.parentElement.querySelectorAll('.reveal');
        let delay = 0;
        siblings.forEach((s, idx) => { if (s === e.target) delay = idx * 80; });
        setTimeout(() => e.target.classList.add('visible'), delay);
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => io.observe(el));

  // Theme toggle
  const root = document.documentElement;
  const btn  = document.getElementById('themeToggle');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  let isDark = localStorage.getItem('theme')
    ? localStorage.getItem('theme') === 'dark'
    : prefersDark;

  function applyTheme() {
    root.setAttribute('data-theme', isDark ? 'dark' : 'light');
    btn.textContent = isDark ? '☀️' : '🌙';
    btn.setAttribute('aria-label', isDark ? 'Mudar para modo claro' : 'Mudar para modo escuro');
  }
  applyTheme();

  btn.addEventListener('click', () => {
    isDark = !isDark;
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    applyTheme();
    btn.style.transition = 'transform .4s ease';
    btn.style.transform = 'rotate(360deg) scale(1.2)';
    setTimeout(() => { btn.style.transform = ''; }, 420);
  });
</script>
</body>
</html>
